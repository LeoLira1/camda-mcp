# Turso database URL (formato: libsql://seu-banco.turso.io)
TURSO_DATABASE_URL=libsql://your-database.turso.io

# Token de autenticação do Turso (gerado em app.turso.tech)
TURSO_AUTH_TOKEN=your-turso-auth-token

# (Opcional) Token para proteger o endpoint MCP com autenticação Bearer
MCP_AUTH_TOKEN=your-secret-token

# Porta do servidor (Railway injeta automaticamente)
PORT=3000
